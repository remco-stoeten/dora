# Marketing is the only thing Vercel builds. Keep the upload small by excluding
# everything the Next build doesn't need — Vercel reinstalls deps and rebuilds
# .next remotely via installCommand/buildCommand.

# Heavy desktop/Rust build artifacts (tens of GB)
apps/desktop/src-tauri/target

# Local caches / build output (regenerated on Vercel)
.turbo
**/.turbo
node_modules
**/node_modules
.next
**/.next

# Bulky binaries and local-only assets
dora-runner
*.AppImage
*.deb
*.rpm
*.dmg
*.msi
*.exe
*.snap
recordings
.tauri-logs
.vercel/output

# Docs media (videos/images, tens of MB) — not consumed by the Fumadocs build,
# which only globs .mdx/.md/meta.json. Keeps the CLI upload small.
docs/assets

# Desktop-only demo media — the Vercel build only touches apps/marketing.
apps/desktop/docker.mp4
